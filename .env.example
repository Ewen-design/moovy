# Public origin used by SvelteKit adapter-node for CSRF / cookies.
# Must be the URL the browser actually hits — https behind Traefik.
ORIGIN=https://moovy.example.com

# Image tag to deploy — `latest`, or a `sha-…` tag for immutable
# deploys and instant rollbacks (see GHCR package page).
MOOVY_TAG=latest

# TVDB API key — required. https://thetvdb.com/api-information
# In production prefer TVDB_API_KEY_FILE (see secrets blocks in compose.yaml).
TVDB_API_KEY=replace-me
